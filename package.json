{
  "name": "ai-resume-analyzer",
  "version": "2.0.0",
  "description": "Production-ready AI Resume Analyzer with ATS Scoring",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "build": "npm run build:backend && npm run build:client",
    "dev": "tsx watch server.ts",
    "dev:client": "npm --prefix client run dev",
    "build:backend": "tsc",
    "build:client": "npm --prefix client run build",
    "docker:start": "docker compose up --build",
    "docker:stop": "docker compose down"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.5.0",
    "mammoth": "^1.9.0",
    "multer": "^2.1.1",
    "openai": "^4.86.2",
    "pdf-parse": "^1.1.1",
    "rate-limit-redis": "^4.2.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
